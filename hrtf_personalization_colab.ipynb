 "cells": [
  {
   "cell_type": "markdown",
   "id": "intro",
   "metadata": {},
   "source": [
    "# HRTF Personalization — Full Pipeline\n",
    "\n",
    "This notebook runs the complete pipeline:\n",
    "1. Install dependencies and clone the repo\n",
    "2. Fetch the HRTFCNN dataset\n",
    "3. Prepare training samples from CIPIC\n",
    "4. Train the conditional model\n",
    "5. Evaluate\n",
    "6. Predict a personalized SOFA file from your ear photos\n",
    "7. Inspect and download the result\n",
    "\n",
    "**Runtime:** Set `Runtime → Change runtime type → T4 GPU` before starting."
   ]
  },
  {
   "cell_type": "markdown",
   "id": "section-setup",
   "metadata": {},
   "source": [
    "## 1 — Setup"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "clone-install",
   "metadata": {},
   "outputs": [],
   "source": [
    "import os\n",
    "\n",
    "REPO_URL = \"https://github.com/cjtruett/applsci-08-02180.git\"  # update if needed\n",
    "REPO_DIR = \"/content/applsci-08-02180\"\n",
    "\n",
    "if not os.path.isdir(REPO_DIR):\n",
    "    !git clone {REPO_URL} {REPO_DIR}\n",
    "\n",
    "%cd {REPO_DIR}\n",
    "!pip install -e . --quiet"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "check-gpu",
   "metadata": {},
   "outputs": [],
   "source": [
    "import torch\n",
    "\n",
    "DEVICE = \"cuda\" if torch.cuda.is_available() else \"cpu\"\n",
    "print(f\"Using device: {DEVICE}\")\n",
    "if DEVICE == \"cuda\":\n",
    "    print(torch.cuda.get_device_name(0))"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "section-drive",
   "metadata": {},
   "source": [
    "### Optional — Mount Google Drive\n",
    "Skip if you don't need to persist checkpoints across sessions."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "mount-drive",
   "metadata": {},
   "outputs": [],
   "source": [
    "USE_DRIVE = False  # set True to persist checkpoints to Drive\n",
    "\n",
    "if USE_DRIVE:\n",
    "    from google.colab import drive\n",
    "    drive.mount(\"/content/drive\")\n",
    "    CHECKPOINT_DIR = \"/content/drive/MyDrive/hrtf_checkpoints\"\n",
    "else:\n",
    "    CHECKPOINT_DIR = f\"{REPO_DIR}/artifacts/checkpoints\"\n",
    "\n",
    "os.makedirs(CHECKPOINT_DIR, exist_ok=True)\n",
    "print(f\"Checkpoints will be saved to: {CHECKPOINT_DIR}\")"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "section-dataset",
   "metadata": {},
   "source": [
    "## 2 — Fetch HRTFCNN Dataset\n",
    "\n",
    "Downloads the CIPIC SOFA files, anthropometry data, and ear photos from the HRTFCNN repository (~600 MB)."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "write-dataset-config",
   "metadata": {},
   "outputs": [],
   "source": [
    "import yaml\n",
    "\n",
    "HRTFCNN_ROOT = \"/tmp/HRTFCNN\"\n",
    "PREPARED_ROOT = f\"{REPO_DIR}/artifacts/prepared\"\n",
    "\n",
    "dataset_config = {\n",
    "    \"dataset\": {\n",
    "        \"source_layout\": \"hrtfcnn\",\n",
    "        \"hrtfcnn_repo_root\": HRTFCNN_ROOT,\n",
    "        \"prepared_root\": PREPARED_ROOT,\n",
    "        \"image_size\": 64,\n",
    "        \"crop\": {\"x\": 50, \"y\": 50, \"width\": 450, \"height\": 450},\n",
    "        \"blur_kernel\": 5,\n",
    "        \"edge_detection\": {\"enabled\": True, \"low_threshold\": 50, \"high_threshold\": 100},\n",
    "        \"anthropometrics\": {\"use_first_n\": 17},\n",
    "    }\n",
    "}\n",
    "\n",
    "DATASET_CONFIG_PATH = \"/tmp/dataset.yaml\"\n",
    "with open(DATASET_CONFIG_PATH, \"w\") as f:\n",
    "    yaml.dump(dataset_config, f)\n",
    "\n",
    "print(\"Dataset config written.\")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "fetch-assets",
   "metadata": {},
   "outputs": [],
   "source": [
    "!hrtf-personalization fetch-hrtfcnn-assets --config {DATASET_CONFIG_PATH}"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "section-prepare",
   "metadata": {},
   "source": [
    "## 3 — Prepare Training Samples\n",
    "\n",
    "Extracts HRIRs and ear-image edge maps from each CIPIC subject and saves them as `.npz` files."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "prepare-cipic",
   "metadata": {},
   "outputs": [],
   "source": [
    "!hrtf-personalization prepare-cipic --config {DATASET_CONFIG_PATH}"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "check-prepared",
   "metadata": {},
   "outputs": [],
   "source": [
    "import json\n",
    "from pathlib import Path\n",
    "\n",
    "manifest = json.loads(Path(f\"{PREPARED_ROOT}/manifest.json\").read_text())\n",
    "print(f\"Subjects: {manifest['num_subjects']}\")\n",
    "print(f\"Total samples: {manifest['num_samples']}\")"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "section-train",
   "metadata": {},
   "source": [
    "## 4 — Train the Conditional Model\n",
    "\n",
    "Trains `ConditionalHRTFEstimator` for 150 epochs with direction and ear-side conditioning."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "write-train-config",
   "metadata": {},
   "outputs": [],
   "source": [
    "CONDITIONAL_CHECKPOINT = f\"{CHECKPOINT_DIR}/conditional.pt\"\n",
    "\n",
    "train_config = {\n",
    "    \"experiment\": {\"name\": \"conditional-hrtfcnn\"},\n",
    "    \"dataset\": {\n",
    "        \"source_layout\": \"hrtfcnn\",\n",
    "        \"hrtfcnn_repo_root\": HRTFCNN_ROOT,\n",
    "        \"prepared_root\": PREPARED_ROOT,\n",
    "        \"image_size\": 64,\n",
    "        \"crop\": {\"x\": 50, \"y\": 50, \"width\": 450, \"height\": 450},\n",
    "        \"blur_kernel\": 5,\n",
    "        \"edge_detection\": {\"enabled\": True, \"low_threshold\": 50, \"high_threshold\": 100},\n",
    "        \"anthropometrics\": {\"use_first_n\": 17},\n",
    "    },\n",
    "    \"training\": {\n",
    "        \"batch_size\": 64,\n",
    "        \"epochs\": 150,\n",
    "        \"learning_rate\": 1.0e-3,\n",
    "        \"seed\": 7,\n",
    "        \"device\": DEVICE,\n",
    "        \"optimizer\": \"adam\",\n",
    "        \"loss\": \"mse\",\n",
    "        \"log_interval_batches\": 25,\n",
    "    },\n",
    "    \"model\": {\n",
    "        \"type\": \"conditional\",\n",
    "        \"anthropometric_dim\": 17,\n",
    "        \"direction_dim\": 2,\n",
    "        \"ear_side_dim\": 1,\n",
    "        \"hrtf_dim\": 200,\n",
    "        \"ear_image_size\": 64,\n",
    "    },\n",
    "    \"output\": {\"checkpoint\": CONDITIONAL_CHECKPOINT},\n",
    "}\n",
    "\n",
    "TRAIN_CONFIG_PATH = \"/tmp/train-conditional.yaml\"\n",
    "with open(TRAIN_CONFIG_PATH, \"w\") as f:\n",
    "    yaml.dump(train_config, f)\n",
    "\n",
    "print(\"Training config written.\")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "train",
   "metadata": {},
   "outputs": [],
   "source": [
    "!hrtf-personalization train-conditional --config {TRAIN_CONFIG_PATH}"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "section-loss-plot",
   "metadata": {},
   "source": [
    "### Training Loss Curve"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "plot-loss",
   "metadata": {},
   "outputs": [],
   "source": [
    "import matplotlib.pyplot as plt\n",
    "\n",
    "checkpoint = torch.load(CONDITIONAL_CHECKPOINT, map_location=\"cpu\")\n",
    "history = checkpoint[\"loss_history\"]\n",
    "\n",
    "plt.figure(figsize=(8, 4))\n",
    "plt.plot(history)\n",
    "plt.xlabel(\"Epoch\")\n",
    "plt.ylabel(\"MSE Loss\")\n",
    "plt.title(\"Training Loss\")\n",
    "plt.tight_layout()\n",
    "plt.show()\n",
    "print(f\"Final loss: {history[-1]:.6f}\")"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "section-evaluate",
   "metadata": {},
   "source": [
    "## 5 — Evaluate"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "write-eval-config",
   "metadata": {},
   "outputs": [],
   "source": [
    "METRICS_PATH = f\"{REPO_DIR}/artifacts/reports/conditional_metrics.json\"\n",
    "\n",
    "eval_config = {\n",
    "    \"evaluation\": {\n",
    "        \"checkpoint\": CONDITIONAL_CHECKPOINT,\n",
    "        \"prepared_root\": PREPARED_ROOT,\n",
    "        \"model_type\": \"conditional\",\n",
    "        \"batch_size\": 64,\n",
    "        \"output_path\": METRICS_PATH,\n",
    "    }\n",
    "}\n",
    "\n",
    "EVAL_CONFIG_PATH = \"/tmp/eval-conditional.yaml\"\n",
    "with open(EVAL_CONFIG_PATH, \"w\") as f:\n",
    "    yaml.dump(eval_config, f)\n",
    "\n",
    "!hrtf-personalization evaluate --config {EVAL_CONFIG_PATH}"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "show-metrics",
   "metadata": {},
   "outputs": [],
   "source": [
    "metrics = json.loads(Path(METRICS_PATH).read_text())\n",
    "print(f\"Samples evaluated : {metrics['num_samples']}\")\n",
    "print(f\"RMSE  mean ± std  : {metrics['rmse_mean']:.4f} ± {metrics['rmse_std']:.4f}\")\n",
    "print(f\"LSD   mean ± std  : {metrics['lsd_mean']:.4f} ± {metrics['lsd_std']:.4f} dB\")"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "section-predict",
   "metadata": {},
   "source": [
    "## 6 — Predict Your Personalized SOFA\n",
    "\n",
    "Upload a photo of each ear, then run the prediction. The output is a `SimpleFreeFieldHRIR` SOFA file at 192 kHz."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "upload-ears",
   "metadata": {},
   "outputs": [],
   "source": [
    "from google.colab import files\n",
    "import shutil\n",
    "\n",
    "print(\"Upload your LEFT ear photo:\")\n",
    "left_upload = files.upload()\n",
    "LEFT_IMAGE = f\"/tmp/{list(left_upload.keys())[0]}\"\n",
    "with open(LEFT_IMAGE, \"wb\") as f:\n",
    "    f.write(list(left_upload.values())[0])\n",
    "\n",
    "print(\"\\nUpload your RIGHT ear photo:\")\n",
    "right_upload = files.upload()\n",
    "RIGHT_IMAGE = f\"/tmp/{list(right_upload.keys())[0]}\"\n",
    "with open(RIGHT_IMAGE, \"wb\") as f:\n",
    "    f.write(list(right_upload.values())[0])\n",
    "\n",
    "print(f\"\\nLeft:  {LEFT_IMAGE}\")\n",
    "print(f\"Right: {RIGHT_IMAGE}\")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "anthro-input",
   "metadata": {},
   "outputs": [],
   "source": [
    "# Paste 17 comma-separated anthropometric values, or leave as None to use the built-in defaults.\n",
    "# Order follows the CIPIC database: head/torso/pinna measurements in cm.\n",
    "ANTHROPOMETRICS = None  # e.g. \"15.6,23.2,20.5,2.6,3.8,11.8,10.5,12.2,37.5,30.0,23.8,45.0,10.7,71.5,37.0,22.75,47.0\"\n",
    "\n",
    "TEMPLATE_SOFA = f\"{REPO_DIR}/template.sofa\"\n",
    "OUTPUT_SOFA = \"/tmp/my_hrtf.sofa\"\n",
    "\n",
    "cmd = [\n",
    "    \"hrtf-personalization predict\",\n",
    "    f\"--checkpoint {CONDITIONAL_CHECKPOINT}\",\n",
    "    f\"--left-image {LEFT_IMAGE}\",\n",
    "    f\"--right-image {RIGHT_IMAGE}\",\n",
    "    f\"--template-sofa {TEMPLATE_SOFA}\",\n",
    "    f\"--output-sofa {OUTPUT_SOFA}\",\n",
    "    f\"--device {DEVICE}\",\n",
    "]\n",
    "if ANTHROPOMETRICS:\n",
    "    cmd.append(f'--anthro \"{ANTHROPOMETRICS}\"')\n",
    "\n",
    "!{' '.join(cmd)}"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "section-inspect",
   "metadata": {},
   "source": [
    "## 7 — Inspect the Output SOFA"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "inspect-sofa",
   "metadata": {},
   "outputs": [],
   "source": [
    "import h5py\n",
    "import numpy as np\n",
    "\n",
    "with h5py.File(OUTPUT_SOFA, \"r\") as f:\n",
    "    ir = np.asarray(f[\"Data.IR\"])          # (M, R, N)\n",
    "    sr = float(np.asarray(f[\"Data.SamplingRate\"])[0])\n",
    "    pos = np.asarray(f[\"SourcePosition\"])  # (M, 3)\n",
    "\n",
    "print(f\"Sample rate : {sr:.0f} Hz\")\n",
    "print(f\"Directions  : {ir.shape[0]}\")\n",
    "print(f\"IR length   : {ir.shape[2]} samples ({ir.shape[2] / sr * 1000:.2f} ms)\")\n",
    "print(f\"Left  peak  : {np.max(np.abs(ir[:, 0, :])):.4f}\")\n",
    "print(f\"Right peak  : {np.max(np.abs(ir[:, 1, :])):.4f}\")\n",
    "\n",
    "ild = 20 * np.log10(\n",
    "    (np.sqrt(np.mean(ir[:, 1, :]**2, axis=-1)) + 1e-12) /\n",
    "    (np.sqrt(np.mean(ir[:, 0, :]**2, axis=-1)) + 1e-12)\n",
    ")\n",
    "print(f\"Mean ILD    : {np.mean(ild):.2f} dB  (0 = balanced, + = right louder)\")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "plot-hrir",
   "metadata": {},
   "outputs": [],
   "source": [
    "# Plot the HRIR for the front direction (az=0, el=0)\n",
    "front_idx = int(np.argmin(np.abs(pos[:, 0]) + np.abs(pos[:, 1])))\n",
    "t_ms = np.arange(ir.shape[2]) / sr * 1000\n",
    "\n",
    "fig, axes = plt.subplots(2, 1, figsize=(10, 5), sharex=True)\n",
    "for ax, ch, label in zip(axes, [0, 1], [\"Left\", \"Right\"]):\n",
    "    ax.plot(t_ms, ir[front_idx, ch, :])\n",
    "    ax.set_ylabel(\"Amplitude\")\n",
    "    ax.set_title(f\"{label} ear — front direction (az={pos[front_idx,0]:.0f}°, el={pos[front_idx,1]:.0f}°)\")\n",
    "    ax.axhline(0, color=\"gray\", linewidth=0.5)\n",
    "axes[-1].set_xlabel(\"Time (ms)\")\n",
    "plt.tight_layout()\n",
    "plt.show()"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "plot-magnitude",
   "metadata": {},
   "outputs": [],
   "source": [
    "# Magnitude spectrum of the front HRIR\n",
    "freqs = np.fft.rfftfreq(ir.shape[2], d=1.0 / sr)\n",
    "\n",
    "fig, ax = plt.subplots(figsize=(10, 4))\n",
    "for ch, label, color in [(0, \"Left\", \"steelblue\"), (1, \"Right\", \"tomato\")]:\n",
    "    mag = np.abs(np.fft.rfft(ir[front_idx, ch, :]))\n",
    "    mag_db = 20 * np.log10(mag + 1e-12)\n",
    "    ax.semilogx(freqs[1:], mag_db[1:], label=label, color=color, alpha=0.85)\n",
    "ax.set_xlabel(\"Frequency (Hz)\")\n",
    "ax.set_ylabel(\"Magnitude (dB)\")\n",
    "ax.set_title(\"HRTF Magnitude — Front Direction\")\n",
    "ax.set_xlim(20, sr / 2)\n",
    "ax.legend()\n",
    "ax.grid(True, which=\"both\", alpha=0.3)\n",
    "plt.tight_layout()\n",
    "plt.show()"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "download-sofa",
   "metadata": {},
   "outputs": [],
   "source": [
    "files.download(OUTPUT_SOFA)"
   ]
  }
 ]
}"
